{
  "name": "vscode-stream-masker",
  "displayName": "Stream Masker",
  "description": "Masks sensitive-looking values in VS Code and provides a secure editor for replacing values without rendering originals.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NA-DEGEN-GIRL/vs-code-sensitive-masking.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:streamMasker.toggleCurrentFile",
    "onCommand:streamMasker.maskCurrentFile",
    "onCommand:streamMasker.unmaskCurrentFile",
    "onCommand:streamMasker.openMaskedPreview",
    "onCommand:streamMasker.openSecureEditor",
    "onCustomEditor:streamMasker.secureEditor"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "streamMasker.toggleCurrentFile",
        "title": "Stream Masker: Toggle Current File Masking",
        "icon": "$(eye)"
      },
      {
        "command": "streamMasker.maskCurrentFile",
        "title": "Stream Masker: Mask Current File"
      },
      {
        "command": "streamMasker.unmaskCurrentFile",
        "title": "Stream Masker: Unmask Current File"
      },
      {
        "command": "streamMasker.openMaskedPreview",
        "title": "Stream Masker: Open Masked Preview",
        "icon": "$(preview)"
      },
      {
        "command": "streamMasker.openSecureEditor",
        "title": "Stream Masker: Open Secure Editor",
        "icon": "$(lock)"
      }
    ],
    "customEditors": [
      {
        "viewType": "streamMasker.secureEditor",
        "displayName": "Stream Masker Secure Editor",
        "selector": [
          {
            "filenamePattern": "**/.[e]nv"
          },
          {
            "filenamePattern": "**/.[e]nv.local"
          },
          {
            "filenamePattern": "**/.[e]nv.development"
          },
          {
            "filenamePattern": "**/.[e]nv.development.local"
          },
          {
            "filenamePattern": "**/.[e]nv.production"
          },
          {
            "filenamePattern": "**/.[e]nv.production.local"
          },
          {
            "filenamePattern": "**/.[e]nv.test"
          },
          {
            "filenamePattern": "**/.[e]nv.test.local"
          },
          {
            "filenamePattern": "**/*secret*"
          },
          {
            "filenamePattern": "**/*credential*"
          },
          {
            "filenamePattern": "**/*token*"
          },
          {
            "filenamePattern": "**/*apikey*"
          },
          {
            "filenamePattern": "**/*api-key*"
          },
          {
            "filenamePattern": "**/*private*"
          },
          {
            "filenamePattern": "**/local.settings.json"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "streamMasker.toggleCurrentFile",
          "group": "navigation",
          "when": "editorTextFocus"
        },
        {
          "command": "streamMasker.openMaskedPreview",
          "group": "navigation",
          "when": "editorTextFocus"
        },
        {
          "command": "streamMasker.openSecureEditor",
          "group": "navigation",
          "when": "editorTextFocus"
        }
      ],
      "editor/context": [
        {
          "command": "streamMasker.toggleCurrentFile",
          "group": "navigation",
          "when": "editorTextFocus"
        },
        {
          "command": "streamMasker.openMaskedPreview",
          "group": "navigation",
          "when": "editorTextFocus"
        },
        {
          "command": "streamMasker.openSecureEditor",
          "group": "navigation",
          "when": "editorTextFocus"
        }
      ],
      "explorer/context": [
        {
          "command": "streamMasker.maskCurrentFile",
          "group": "navigation"
        },
        {
          "command": "streamMasker.unmaskCurrentFile",
          "group": "navigation"
        },
        {
          "command": "streamMasker.openMaskedPreview",
          "group": "navigation"
        },
        {
          "command": "streamMasker.openSecureEditor",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Stream Masker",
      "properties": {
        "streamMasker.extraAutoMaskGlobs": {
          "type": "array",
          "default": [],
          "description": "Additional glob patterns that should be visually masked automatically."
        },
        "streamMasker.mask": {
          "type": "string",
          "default": "********",
          "description": "Text drawn over sensitive-looking values in the editor."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.9.3"
  }
}
